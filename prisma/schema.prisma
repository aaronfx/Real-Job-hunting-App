// CareerOps Cloud - data model
// A single-user system. We don't model multi-tenancy; the whole DB is yours.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Your profile. One row, kept in sync via /profile page.
model Profile {
  id                 String   @id @default(cuid())
  fullName           String
  email              String
  location           String?
  targetRoles        String[] @default([])
  archetype          String?  // e.g. "backend engineer", "forex educator"
  yearsExperience    Int?
  salaryMinUsd       Int?
  salaryTargetUsd    Int?
  workAuth           String?  // e.g. "US citizen", "EU remote"
  workPreference     String?  // "remote" | "hybrid" | "onsite"
  dealbreakers       String?  @db.Text
  strengths          String?  @db.Text
  weaknesses         String?  @db.Text
  notes              String?  @db.Text
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

// Your base CV in markdown. Tailored versions live on Evaluation.
model CV {
  id        String   @id @default(cuid())
  label     String   @default("default")
  markdown  String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([label])
}

// A job we've seen or been asked about.
model Job {
  id            String   @id @default(cuid())
  url           String?  @unique
  company       String
  title         String
  location      String?
  remote        Boolean  @default(false)
  description   String   @db.Text
  salaryText    String?
  source        String?  // "manual" | "greenhouse" | "ashby" | "lever" | ...
  portalId      String?
  portal        Portal?  @relation(fields: [portalId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  evaluations   Evaluation[]
}

// A single Claude evaluation of a Job.
model Evaluation {
  id              String   @id @default(cuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Overall score 0-5, letter grade A-F
  score           Float
  grade           String
  recommendation  String   // "apply-now" | "strong" | "consider" | "skip"

  // Six-block analysis, stored as JSON for flexibility
  roleSummary     Json?
  cvMatch         Json?
  levelStrategy   Json?
  compensation    Json?
  personalization Json?
  interviewPrep   Json?

  // Dimension scores (the 10-dim rubric)
  dimensions      Json?

  // Keywords Claude wants on the tailored CV
  keywords        String[] @default([])

  // The tailored CV markdown generated by Claude for this role
  tailoredCv      String?  @db.Text

  // PDF artifact
  pdfPath         String?

  status          String   @default("pending") // "pending" | "running" | "done" | "error"
  errorMessage    String?  @db.Text

  application     Application?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// The state you're in with a specific role.
model Application {
  id             String   @id @default(cuid())
  evaluationId   String   @unique
  evaluation     Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  status         String   @default("not-applied") // "not-applied" | "applied" | "phone-screen" | "interviewing" | "offer" | "rejected" | "withdrawn"
  appliedAt      DateTime?
  notes          String?  @db.Text
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// A company career portal we scan automatically.
model Portal {
  id        String   @id @default(cuid())
  company   String
  kind      String   // "greenhouse" | "ashby" | "lever"
  slug      String   // the company identifier on that ATS
  enabled   Boolean  @default(true)
  lastScan  DateTime?
  jobs      Job[]
  createdAt DateTime @default(now())

  @@unique([kind, slug])
}

// Growing library of interview stories extracted across evaluations.
model InterviewStory {
  id          String   @id @default(cuid())
  title       String
  situation   String   @db.Text
  task        String   @db.Text
  action      String   @db.Text
  result      String   @db.Text
  tags        String[] @default([])
  sourceEvalId String?
  createdAt   DateTime @default(now())
}
