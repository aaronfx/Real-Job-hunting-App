# ---- Required ----

# Anthropic API key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Postgres (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Redis for BullMQ queue (Railway Redis plugin)
REDIS_URL=redis://default:pass@host:6379

# Single-user auth
APP_PASSWORD=change-me-to-something-strong
SESSION_SECRET=generate-a-32+-char-random-string-for-cookie-encryption

# ---- Optional ----

# Which Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Where the web app lives (used by worker/cron to hit health and callback)
PUBLIC_APP_URL=https://your-app.up.railway.app

# Shared secret for cron endpoint (GitHub Actions will send this)
CRON_SECRET=another-random-string

# Anthropic defaults
CLAUDE_MAX_TOKENS=4096

# Node environment
NODE_ENV=production
